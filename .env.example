# ───────────────────────── Salmor environment ─────────────────────────
# Copy to .env for local dev. On Railway, set these as service/shared variables.
# Money is always in integer paise. Never commit a real .env.

# Runtime
ENVIRONMENT=development           # development | staging | production
APP_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000        # Next.js app origin (CORS + Meta OAuth redirect)
CORS_ALLOWED_ORIGINS=                     # prod only: comma-separated; falls back to WEB_BASE_URL
LOG_LEVEL=INFO
RAILWAY_REGION=southeast-asia      # nearest region; India residency is a later gate
PIPELINE_INLINE=true               # dev: run phases in-request; prod: false (enqueue workers)

# Mock switches — keep true for the walking skeleton (no external accounts needed)
MOCK_META=true
MOCK_WHATSAPP=true
MOCK_RAZORPAY=true
MOCK_LLM=true                      # true => deterministic stub LLM; false => real provider
MOCK_OTP=true

# Datastores
DATABASE_URL=postgresql+psycopg://leadpilot:leadpilot@localhost:5432/leadpilot
DATABASE_URL_POOLED=               # PgBouncer transaction-pool URL (falls back to DATABASE_URL)
DATABASE_MIGRATION_URL=            # migration role (falls back to DATABASE_URL)
APP_TENANT_DB_ROLE=leadpilot_app   # non-superuser role used by the app (RLS applies)
APP_PLATFORM_DB_ROLE=              # BYPASSRLS role for webhooks/admin/cron (prod: leadpilot_platform)
DB_POOL_SIZE=3                     # per-process SQLAlchemy pool size
DB_MAX_OVERFLOW=7                  # burst connections above the pool
TRUST_PROXY=false                  # true in prod behind a proxy — read client IP from X-Forwarded-For
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-only-change-me
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_MIN=43200
TOKEN_ENCRYPTION_KEY=dev-only-32byte-key-change-me____   # encrypts Meta tokens at rest

# LLM router (used when MOCK_LLM=false)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_REASONING_MODEL=claude-opus-4-8
LLM_CREATIVE_MODEL=claude-haiku-4-5-20251001   # gemini-1.5-* is retired; use gemini-2.x if overriding
LLM_CLOSER_MODEL=claude-haiku-4-5-20251001
LLM_DAILY_BUDGET_PER_ACCOUNT_PAISE=5000   # ₹50/account/day LLM spend cap
LLM_MAX_OUTPUT_TOKENS=2048
LLM_REQUEST_TIMEOUT_S=30

# UGC video generation via fal.ai (Kling). Leave FAL_API_KEY blank to use the mock.
FAL_API_KEY=
FAL_VIDEO_MODEL=fal-ai/kling-video/v1/standard/text-to-video
FAL_VIDEO_DURATION=5
FAL_POLL_TIMEOUT_S=180
FAL_POLL_INTERVAL_S=3

# Meta (used when MOCK_META=false)
META_APP_ID=
META_APP_SECRET=
# Founder/agency BM System User token — the review-free path runs every client's ads with
# this one token (per-client tokens on meta_connections take precedence).
META_SYSTEM_USER_TOKEN=
META_MIN_ADSET_DAILY_PAISE=9000          # Meta's ~INR ad-set daily minimum; tiers below fold
META_GRAPH_API_VERSION=v23.0
META_WEBHOOK_VERIFY_TOKEN=

# WhatsApp (used when MOCK_WHATSAPP=false)
WHATSAPP_PROVIDER=cloud            # cloud (Meta direct) | bsp (aggregator middleware)
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dev-verify-token
# BSP (only when WHATSAPP_PROVIDER=bsp; see docs/WHATSAPP_PROVIDERS.md)
BSP_BASE_URL=
BSP_API_KEY=

# Razorpay (used when MOCK_RAZORPAY=false)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Object storage (Cloudflare R2 / S3) — used when MOCK assets disabled
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=leadpilot-assets
R2_REGION=auto

# OTP (used when MOCK_OTP=false)
OTP_PROVIDER=msg91
MSG91_API_KEY=
MSG91_TEMPLATE_ID=                       # DLT-registered OTP template (mandatory in India)

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Scaling knobs
OPTIMIZER_SHARD_COUNT=4
DEFAULT_TRUST_THRESHOLD=2
