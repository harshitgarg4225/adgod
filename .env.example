# ───────────────────────── LeadPilot environment ─────────────────────────
# Copy to .env for local dev. On Railway, set these as service/shared variables.
# Money is always in integer paise. Never commit a real .env.

# Runtime
ENVIRONMENT=development           # development | staging | production
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
RAILWAY_REGION=southeast-asia      # nearest region; India residency is a later gate

# Mock switches — keep true for the walking skeleton (no external accounts needed)
MOCK_META=true
MOCK_WHATSAPP=true
MOCK_RAZORPAY=true
MOCK_LLM=true                      # true => deterministic stub LLM; false => real provider
MOCK_OTP=true

# Datastores
DATABASE_URL=postgresql+psycopg://leadpilot:leadpilot@localhost:5432/leadpilot
DATABASE_URL_POOLED=               # PgBouncer transaction-pool URL (falls back to DATABASE_URL)
DATABASE_MIGRATION_URL=            # migration role (falls back to DATABASE_URL)
APP_TENANT_DB_ROLE=leadpilot_app   # non-superuser role used by the app (RLS applies)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=dev-only-change-me
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_MIN=43200
TOKEN_ENCRYPTION_KEY=dev-only-32byte-key-change-me____   # encrypts Meta system-user tokens at rest

# LLM router (used when MOCK_LLM=false)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_REASONING_MODEL=claude-opus-4-8
LLM_CREATIVE_MODEL=gemini-1.5-flash
LLM_CLOSER_MODEL=gemini-1.5-flash
LLM_DAILY_BUDGET_PER_ACCOUNT_PAISE=5000   # ₹50/account/day LLM spend cap

# Meta (used when MOCK_META=false)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=

# WhatsApp Cloud API (used when MOCK_WHATSAPP=false)
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=dev-verify-token

# Razorpay (used when MOCK_RAZORPAY=false)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Object storage (Cloudflare R2 / S3) — used when MOCK assets disabled
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=leadpilot-assets
R2_REGION=auto

# OTP (used when MOCK_OTP=false)
OTP_PROVIDER=msg91
MSG91_API_KEY=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Scaling knobs
OPTIMIZER_SHARD_COUNT=4
DEFAULT_TRUST_THRESHOLD=2
