# ───────────────── Salmor PRODUCTION env (Railway shared variables) ─────────────────
# Copy values into Railway's shared variable group. Flip each MOCK_* to false only once
# the matching real credentials below are filled and the provider is approved/live.
# Money is integer paise. NEVER commit real secrets.

ENVIRONMENT=production
APP_BASE_URL=https://api.yourdomain.com
WEB_BASE_URL=https://app.yourdomain.com          # the Next.js app origin
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com  # comma-separated allowed origins
LOG_LEVEL=INFO
RAILWAY_REGION=southeast-asia            # nearest region; see India-residency gate in GO_LIVE.md
PIPELINE_INLINE=false                    # enqueue worker jobs (don't run phases in-request)

# Datastores (use Railway plugin references, e.g. ${{Postgres.DATABASE_URL}} with +psycopg)
DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/railway
DATABASE_URL_POOLED=                      # PgBouncer transaction-pool URL (recommended)
DATABASE_MIGRATION_URL=                   # superuser/migration role (falls back to DATABASE_URL)
APP_TENANT_DB_ROLE=leadpilot_app          # non-superuser role the app runs as (RLS applies)
APP_PLATFORM_DB_ROLE=leadpilot_platform   # BYPASSRLS role for webhooks/admin/cron
REDIS_URL=redis://default:PASS@HOST:6379

# Auth / crypto — generate strong random values (the app REFUSES to boot with the dev defaults)
JWT_SECRET=__set_32+_random_bytes__
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_MIN=43200
TOKEN_ENCRYPTION_KEY=__set_32_bytes__     # encrypts Meta system-user tokens at rest

# ── Flip to false as each integration goes live ──
MOCK_LLM=false
MOCK_META=false
MOCK_WHATSAPP=false
MOCK_RAZORPAY=false
MOCK_OTP=false

# LLM router
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
LLM_REASONING_MODEL=claude-opus-4-8
LLM_CREATIVE_MODEL=gemini-1.5-flash
LLM_CLOSER_MODEL=gemini-1.5-flash
LLM_DAILY_BUDGET_PER_ACCOUNT_PAISE=5000
LLM_MAX_OUTPUT_TOKENS=2048
LLM_REQUEST_TIMEOUT_S=30

# UGC video generation via fal.ai (Kling). Blank FAL_API_KEY => falls back to a placeholder.
FAL_API_KEY=
FAL_VIDEO_MODEL=fal-ai/kling-video/v1/standard/text-to-video
FAL_VIDEO_DURATION=5
FAL_POLL_TIMEOUT_S=180
FAL_POLL_INTERVAL_S=3

# Meta (after app review + Business verification)
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=__set__

# WhatsApp (after WABA onboarding + template approval)
WHATSAPP_PROVIDER=cloud                   # cloud | bsp
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=__set__
BSP_BASE_URL=                             # only when WHATSAPP_PROVIDER=bsp
BSP_API_KEY=

# Razorpay (after account activation + UPI Autopay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Object storage (Cloudflare R2 / S3 ap-south-1 for residency)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=leadpilot-assets
R2_REGION=auto

# OTP
OTP_PROVIDER=msg91
MSG91_API_KEY=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Scaling
OPTIMIZER_SHARD_COUNT=4
DEFAULT_TRUST_THRESHOLD=2

# Web service (build-time, inlined into the client bundle)
NEXT_PUBLIC_API_BASE=https://api.yourdomain.com/api/v1
